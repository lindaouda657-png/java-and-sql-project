<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane styleClass="page-container"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.marketplace.shop.controller.ReviewsController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="top-bar">
            <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
            <Button text="← Back" onAction="#handleBack" styleClass="secondary-button"/>
            <Label text="Customer Reviews" styleClass="page-title"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="10">
            <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>
            <TableView fx:id="reviewsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colProduct" text="Product" prefWidth="200"/>
                    <TableColumn fx:id="colCustomer" text="Customer" prefWidth="180"/>
                    <TableColumn fx:id="colRate" text="Rating (1-5)" prefWidth="100"/>
                    <TableColumn fx:id="colTopic" text="Review" prefWidth="380"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
