<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane styleClass="page-container"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.marketplace.shop.controller.CategoryProductsController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="top-bar">
            <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
            <Button text="← Back" onAction="#handleBack" styleClass="secondary-button"/>
            <Label fx:id="titleLabel" text="Products" styleClass="page-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="searchField" promptText="Search products..." prefWidth="180"/>
            <Button text="Search" onAction="#handleSearch" styleClass="secondary-button"/>
            <Button text="🛒 Cart" onAction="#goToCart" styleClass="ghost-button"/>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" styleClass="transparent-scroll">
            <VBox spacing="16">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <FlowPane fx:id="productsPane" hgap="18" vgap="18" prefWrapLength="900"/>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
