<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane styleClass="page-container"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.marketplace.shop.controller.ProductsController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="top-bar">
            <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
            <Button text="← Back" onAction="#handleBack" styleClass="secondary-button"/>
            <Label text="Product Management" styleClass="page-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="searchField" promptText="Search products..." prefWidth="200"/>
            <Button text="Search" onAction="#handleSearch" styleClass="primary-button"/>
        </HBox>
    </top>
    <center>
        <HBox spacing="16">
            <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>
            <VBox spacing="15" HBox.hgrow="ALWAYS">
                <TableView fx:id="productTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colCode" text="Code" prefWidth="100"/>
                        <TableColumn fx:id="colName" text="Name" prefWidth="200"/>
                        <TableColumn fx:id="colPrice" text="Price" prefWidth="100"/>
                        <TableColumn fx:id="colQty" text="Qty" prefWidth="60"/>
                        <TableColumn fx:id="colCategory" text="Category" prefWidth="130"/>
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
                    </columns>
                </TableView>
            </VBox>
            <VBox spacing="10" prefWidth="220" styleClass="image-side-panel">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                <Label text="Product photo" styleClass="field-label"/>
                <StackPane styleClass="product-image-box" prefHeight="180">
                    <ImageView fx:id="previewImage" fitWidth="190" fitHeight="170" preserveRatio="true"/>
                </StackPane>
                <Label fx:id="imagePathLabel" text="No image" styleClass="muted-label" wrapText="true"/>
                <Button fx:id="uploadImageButton" text="📷  Upload photo" onAction="#handleUploadImage" styleClass="secondary-button" maxWidth="Infinity"/>
            </VBox>
        </HBox>
    </center>
    <bottom>
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="form-bar">
            <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
            <TextField fx:id="codeField" promptText="Code" prefWidth="100"/>
            <TextField fx:id="nameField" promptText="Name" prefWidth="160"/>
            <TextField fx:id="priceField" promptText="Price" prefWidth="80"/>
            <TextField fx:id="qtyField" promptText="Qty" prefWidth="60"/>
            <ComboBox fx:id="categoryCombo" promptText="Category" prefWidth="120"/>
            <ComboBox fx:id="statusCombo" promptText="Status" prefWidth="120"/>
            <Button fx:id="addButton" text="Add" onAction="#handleAdd" styleClass="primary-button"/>
            <Button fx:id="updateButton" text="Update" onAction="#handleUpdate" styleClass="secondary-button"/>
            <Button fx:id="deleteButton" text="Delete" onAction="#handleDelete" styleClass="danger-button"/>
        </HBox>
    </bottom>
</BorderPane>
