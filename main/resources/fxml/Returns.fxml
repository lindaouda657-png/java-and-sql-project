<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane styleClass="page-container"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.marketplace.shop.controller.ReturnsController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="top-bar">
            <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
            <Button text="← Back" onAction="#handleBack" styleClass="secondary-button"/>
            <Label text="Returns" styleClass="page-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Refresh" onAction="#handleRefresh" styleClass="secondary-button"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="15">
            <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>
            <TableView fx:id="returnsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId"      text="ID"       prefWidth="60"/>
                    <TableColumn fx:id="colProduct" text="Product"  prefWidth="200"/>
                    <TableColumn fx:id="colOrder"   text="Order"    prefWidth="80"/>
                    <TableColumn fx:id="colRefund"  text="Refund"   prefWidth="100"/>
                    <TableColumn fx:id="colReason"  text="Reason"   prefWidth="280"/>
                    <TableColumn fx:id="colDate"    text="Date"     prefWidth="120"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
