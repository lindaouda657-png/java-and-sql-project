<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane styleClass="page-container"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.marketplace.shop.controller.AdminProfileController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="top-bar">
            <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
            <Button text="← Back" onAction="#handleBack" styleClass="secondary-button"/>
            <Label text="Admin Profile" styleClass="page-title"/>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" styleClass="transparent-scroll">
            <VBox alignment="TOP_CENTER" spacing="20">
                <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>

                <VBox spacing="14" styleClass="auth-card" maxWidth="520">
                    <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>
                    <Label text="Administrator Account" styleClass="title-label"/>
                    <Label text="Update your administrator details below" styleClass="muted-label"/>

                    <Label text="Full name" styleClass="field-label"/>
                    <TextField fx:id="nameField"/>
                    <Label text="Email" styleClass="field-label"/>
                    <TextField fx:id="emailField" editable="false" styleClass="read-only-field"/>
                    <Label text="Role" styleClass="field-label"/>
                    <TextField fx:id="roleField" editable="false" styleClass="read-only-field"/>

                    <Separator/>
                    <Label text="Address" styleClass="field-label"/>
                    <TextField fx:id="streetField" promptText="Street"/>
                    <HBox spacing="10">
                        <TextField fx:id="buildingField" promptText="Building #" HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="apartmentField" promptText="Apartment #" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <TextField fx:id="cityField" promptText="City"/>

                    <Button text="Save changes" onAction="#handleSave" styleClass="primary-button" maxWidth="Infinity" prefHeight="40"/>
                </VBox>

                <VBox spacing="14" styleClass="auth-card" maxWidth="520">
                    <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>
                    <Label text="Change Password" styleClass="title-label"/>
                    <Label text="Enter your current password to set a new one" styleClass="muted-label"/>

                    <Label text="Current password" styleClass="field-label"/>
                    <PasswordField fx:id="currentPassField" promptText="Current password"/>
                    <Label text="New password" styleClass="field-label"/>
                    <PasswordField fx:id="newPassField" promptText="New password"/>
                    <Label text="Confirm new password" styleClass="field-label"/>
                    <PasswordField fx:id="confirmPassField" promptText="Confirm new password"/>

                    <Button text="Change Password" onAction="#handleChangePassword" styleClass="secondary-button" maxWidth="Infinity" prefHeight="40"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
